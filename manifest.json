{
  "manifest_version": 3,
  "name": "GHA View Enhancer",
  "description": "Filter toolbar for GitHub Actions run pages — hide/show matrix jobs by status.",
  "version": "0.1.0",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*/actions/runs/*"],
      "js": [
        "src/statusDetector.js",
        "src/filter.js",
        "src/toolbar.js",
        "src/content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"]
}
